PRIORITY(NON-PREEMPTIVE)


#include <stdio.h>

struct process
{
    int pid, at, bt, pr;
    int ct, wt, tat;
    int completed;
};

int main()
{
    struct process p[20];
    int n, i, time = 0, completed = 0;
    int gantt[20], gtime[20], k = 0;
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        p[i].pid = i+1;
        printf("Enter AT BT PR for P%d: ",i+1);
        scanf("%d %d %d",&p[i].at,&p[i].bt,&p[i].pr);
        p[i].completed = 0;
    }

    while(completed < n)
    {
        int idx = -1;
        int highest_pr = 9999;

        for(i=0;i<n;i++)
        {
            if(p[i].at <= time && p[i].completed == 0)
            {
                if(p[i].pr < highest_pr)
                {
                    highest_pr = p[i].pr;
                    idx = i;
                }
            }
        }

        if(idx != -1)
        {
            gantt[k] = idx;
            gtime[k] = time;
            k++;

            time += p[idx].bt;

            p[idx].ct = time;
            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;

            avg_wt += p[idx].wt;
            avg_tat += p[idx].tat;

            p[idx].completed = 1;
            completed++;
        }
        else
        {
            time++;
        }
    }

    gtime[k] = time;

    printf("\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].pid,p[i].at,p[i].bt,p[i].pr,
        p[i].ct,p[i].tat,p[i].wt);
    }

    printf("\nAverage WT = %.2f",avg_wt/n);
    printf("\nAverage TAT = %.2f\n",avg_tat/n);

    printf("\nGantt Chart:\n");

    for(i=0;i<k;i++)
    {
        printf("| P%d ",gantt[i]+1);
    }
    printf("|\n");

    for(i=0;i<=k;i++)
    {
        printf("%d     ",gtime[i]);
    }

    return 0;
}




PRIPRITY(PREEMPTIVE)


#include <stdio.h>

int main()
{
    int n, i, time = 0, completed = 0;
    int at[20], bt[20], pr[20];
    int rt[20], ct[20], tat[20], wt[20];
    int gantt[100];
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter AT BT PR for P%d: ",i+1);
        scanf("%d %d %d",&at[i],&bt[i],&pr[i]);
        rt[i]=bt[i];
    }

    while(completed<n)
    {
        int idx=-1;
        int highest_pr=9999;

        for(i=0;i<n;i++)
        {
            if(at[i]<=time && rt[i]>0)
            {
                if(pr[i]<highest_pr)
                {
                    highest_pr=pr[i];
                    idx=i;
                }
            }
        }

        if(idx!=-1)
        {
            gantt[time]=idx;
            rt[idx]--;
            time++;

            if(rt[idx]==0)
            {
                completed++;

                ct[idx]=time;
                tat[idx]=ct[idx]-at[idx];
                wt[idx]=tat[idx]-bt[idx];

                avg_wt+=wt[idx];
                avg_tat+=tat[idx];
            }
        }
        else
        {
            gantt[time]=-1;
            time++;
        }
    }

    printf("\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],pr[i],ct[i],tat[i],wt[i]);
    }

    printf("\nAverage WT = %.2f",avg_wt/n);
    printf("\nAverage TAT = %.2f\n",avg_tat/n);

    printf("\nGantt Chart:\n");

    for(i=0;i<time;i++)
    {
        if(gantt[i]==-1)
            printf("| Idle ");
        else
            printf("| P%d ",gantt[i]+1);
    }

    printf("|\n0");

    for(i=1;i<=time;i++)
    {
        printf("    %d",i);
    }

    return 0;
}
