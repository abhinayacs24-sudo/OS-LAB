priority scheduling

#include <stdio.h>

int main() {
    int n, i, q;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], at[n];

    for(i = 0; i < n; i++) {
        printf("\nProcess P%d\n", i + 1);

        printf("Arrival Time: ");
        scanf("%d", &at[i]);

        printf("Burst Time: ");
        scanf("%d", &bt[i]);
    }

    printf("\nEnter Time Quantum: ");
    scanf("%d", &q);

    int rt[n], wt[n], tat[n], ct[n];
    int visited[n];

    for(i = 0; i < n; i++) {
        rt[i] = bt[i];
        visited[i] = 0;
    }

    int queue[100], front = 0, rear = 0;
    int time = 0, completed = 0;

    for(i = 0; i < n; i++) {
        if(at[i] == 0) {
            queue[rear++] = i;
            visited[i] = 1;
        }
    }

    printf("\nGantt Chart:\n| ");

    while(completed < n) {

       
        if(front == rear) {
            time++;
            for(i = 0; i < n; i++) {
                if(at[i] <= time && visited[i] == 0) {
                    queue[rear++] = i;
                    visited[i] = 1;
                }
            }
            continue;
        }

        int i = queue[front++];

        printf("P%d | ", i + 1);

        if(rt[i] <= q) {
            time += rt[i];
            rt[i] = 0;

            ct[i] = time;
            tat[i] = ct[i] - at[i];
            wt[i] = tat[i] - bt[i];

            completed++;
        } else {
            time += q;
            rt[i] -= q;
        }

        for(int j = 0; j < n; j++) {
            if(at[j] <= time && visited[j] == 0) {
                queue[rear++] = j;
                visited[j] = 1;
            }
        }

        if(rt[i] > 0) {
            queue[rear++] = i;
        }
    }

    printf("\n0 ");

    
    for(i = 0; i < n; i++) {
        rt[i] = bt[i];
        visited[i] = 0;
    }

    front = rear = 0;
    time = 0;

    for(i = 0; i < n; i++) {
        if(at[i] == 0) {
            queue[rear++] = i;
            visited[i] = 1;
        }
    }

    while(1) {
        if(front == rear) {
            time++;
            int added = 0;
            for(i = 0; i < n; i++) {
                if(at[i] <= time && visited[i] == 0) {
                    queue[rear++] = i;
                    visited[i] = 1;
                    added = 1;
                }
            }
            if(!added) break;
            continue;
        }

        int i = queue[front++];

        if(rt[i] <= q) {
            time += rt[i];
            rt[i] = 0;
        } else {
            time += q;
            rt[i] -= q;
        }

        printf("%d ", time);

        for(int j = 0; j < n; j++) {
            if(at[j] <= time && visited[j] == 0) {
                queue[rear++] = j;
                visited[j] = 1;
            }
        }

        if(rt[i] > 0) {
            queue[rear++] = i;
        }

        
        int done = 1;
        for(int k = 0; k < n; k++) {
            if(rt[k] > 0) {
                done = 0;
                break;
            }
        }
        if(done) break;
    }

  
    float total_wt = 0, total_tat = 0;

    printf("\n\nProcess\tAT\tBT\tCT\tWT\tTAT\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1, at[i], bt[i], ct[i], wt[i], tat[i]);

        total_wt += wt[i];
        total_tat += tat[i];
    }

    printf("\nAverage WT  = %.2f", total_wt / n);
    printf("\nAverage TAT = %.2f\n", total_tat / n);

    return 0;
}
